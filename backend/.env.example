# FinGuard AI — Environment Variables

# ==============================
# AI — Nebius Token Factory (Open Models ONLY)
# ==============================
NEBIUS_API_KEY=your_nebius_api_key_here
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1

# Model Routing Tiers — configure per Nebius Token Factory catalog at deploy time
# Examples: deepseek-ai/DeepSeek-R1, Qwen/Qwen2.5-72B-Instruct, meta-llama/Meta-Llama-3.1-70B-Instruct-fast
NEBIUS_REASONING_MODEL=
NEBIUS_LONG_CONTEXT_MODEL=
NEBIUS_EXTRACTION_MODEL=
NEBIUS_CHAT_MODEL=
NEBIUS_EMBEDDING_MODEL=

# ==============================
# Database
# ==============================
# SQLite (local dev):
DATABASE_URL=sqlite+aiosqlite:///./finguard.db
# Neon PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.neon.tech/finguard

# ==============================
# Auth (JWT)
# ==============================
SECRET_KEY=change_this_to_a_long_random_secret_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ==============================
# App
# ==============================
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ==============================
# ChromaDB
# ==============================
CHROMA_PERSIST_DIR=./chroma_db

# ==============================
# Notifications (optional)
# ==============================
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# ==============================
# Export
# ==============================
EXPORT_DIR=./exports
